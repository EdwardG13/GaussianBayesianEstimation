b2bce1e721d2"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
   RowBox[{"PDF", "[", 
    RowBox[{
     RowBox[{"UniformDistribution", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"\[Mu]0", "-", 
         FractionBox["\[CapitalDelta]", "2"]}], ",", 
        RowBox[{"\[Mu]0", "+", 
         FractionBox["\[CapitalDelta]", "2"]}]}], "}"}], "]"}], ",", 
     "\[Theta]"}], "]"}]}], " ", 
  RowBox[{"(*", 
   RowBox[{"Uniform", " ", "prior"}], " ", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"likelihood", "[", 
     RowBox[{"\[Theta]_", ",", "x_", ",", "x0_"}], "]"}], ":=", 
    RowBox[{"PDF", "[", 
     RowBox[{
      RowBox[{"NormalDistribution", "[", 
       RowBox[{
        RowBox[{"x0", "+", "\[Theta]"}], ",", "Vxx"}], "]"}], ",", "x"}], 
     "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Gaussian", " ", "likelihood", " ", "of", " ", "x"}], "-", 
    RowBox[{"homodyne", " ", 
     RowBox[{"measurements", ".", " ", "This"}], " ", "comes", " ", "the", " ",
      "p"}], "-", 
    RowBox[{"marginal", " ", "of", " ", "the", " ", 
     RowBox[{"(", "Gaussian", ")"}], " ", "Wigner", " ", "function"}]}], " ", 
   "*)"}]}]}], "Input",
 CellChangeTimes->{{3.982397653610895*^9, 3.982397712255142*^9}, {
  3.9823978018341885`*^9, 3.982397801938492*^9}, {3.982398488403612*^9, 
