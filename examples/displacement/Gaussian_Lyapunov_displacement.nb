Cell[CellGroupData[{

Cell[TextData[{
 "Basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "\[CapitalDelta]x", ",", 
     SuperscriptBox["\[CapitalDelta]x", "2"]}]}], TraditionalForm]],
  ExpressionUUID->"d01baf6f-6d6f-af43-900b-e49f234f327f"],
 "} with uniform prior (shows no improvement)"
}], "Section",
 CellChangeTimes->{{3.9800641916158295`*^9, 3.9800641997729607`*^9}, 
   3.9821318203727875`*^9, {3.9821354050378075`*^9, 3.9821354289465313`*^9}, {
   3.98239800613912*^9, 3.9823980065618153`*^9}, {3.9829399710207577`*^9, 
   3.982939973811844*^9}, {3.9830391388696327`*^9, 
   3.983039178460026*^9}},ExpressionUUID->"c0e0c3d3-2878-cb4c-867b-\
2e7aed44f541"],

Cell[TextData[{
 "Basis ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "i"], TraditionalForm]],ExpressionUUID->
  "9f16164f-c7bf-1b44-a8dc-46cdf9d79ef2"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "\[CapitalDelta]x", ",", 
     SuperscriptBox["\[CapitalDelta]x", "2"]}]}], TraditionalForm]],
  ExpressionUUID->"ad4b3a57-dc4c-6c4d-b454-08df3ecdcde6"],
 "} where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]x", "=", 
    RowBox[{
     OverscriptBox["x", "^"], "-", 
     SubscriptBox[
      RowBox[{"\[LeftAngleBracket]", "x", "\[RightAngleBracket]"}], 
      SubscriptBox["\[Rho]", "0"]]}]}], TraditionalForm]],ExpressionUUID->
  "8608a926-66a4-424b-a7b8-ec7428bee742"],
 ".\n\nIt turns out that this has the same MSL as the basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "\[CapitalDelta]x"}]}], TraditionalForm]],
  ExpressionUUID->"05b85e3b-89ce-6649-ab2c-2e0ed4bde6fd"],
 "}, which implies that ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalDelta]x", "2"], TraditionalForm]],ExpressionUUID->
  "7614473d-f5f7-c84c-9462-87bd074e1f0d"],
 " is not included in the posterior mean.i d"
}], "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.982592757317745*^9, 3.9825928569227047`*^9}, {
