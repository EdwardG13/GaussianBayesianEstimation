Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Means", ":", " ", 
      RowBox[{"<", "x", 
       SubscriptBox[">", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", "\[Theta]", ")"}]}]]}]}], "=", 
     RowBox[{
      SubscriptBox["x", "0"], "+", "theta"}]}], ",", " ", 
    RowBox[{
     RowBox[{"<", "p", 
      SubscriptBox[">", 
       RowBox[{"\[Rho]", 
        RowBox[{"(", "\[Theta]", ")"}]}]]}], "=", 
     RowBox[{
      SubscriptBox["p", "0"], " ", "and", " ", "a", " ", "diagonal", " ", 
      "covariance", " ", "matrix", " ", "V"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
      "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Gaussian", " ", "prior"}], " ", "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"First", " ", "moments", " ", "of", " ", "rho0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avgx", "=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"x0", "+", "\[Theta]"}], ")"}], " ", 
        RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], " ", ";"}], "\n", 
   RowBox[{
    RowBox[{"avgp", "=", "p0"}], " ", ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Second", " ", "moments", " ", "of", " ", "rho0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avgx2\[Rho]0", "=", 
     RowBox[{
      RowBox[{"Integrate", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Vxx", "+", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}], ")"}], " ", 
         RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"\[Theta]", ",", 
          RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
        RowBox[{"Assumptions", "->", 
         RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}], "//", "Simplify"}]}], 
    ";"}], "\n", 
   RowBox[{
    RowBox[{"avgp2\[Rho]0", "=", 
     RowBox[{"Vpp", "+", 
      SuperscriptBox["p0", "2"]}]}], ";"}], "\n", "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Gram", " ", "matrix"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Gmat", "=", 
     TagBox[
      RowBox[{"(", "\[NoBreak]", GridBox[{
         {"1", "0", "0"},
         {"0", 
          RowBox[{"avgx2\[Rho]0", "-", 
           SuperscriptBox["avgx", "2"]}], "0"},
         {"0", "0", 
          RowBox[{"avgp2\[Rho]0", "-", 
           SuperscriptBox["avgp", "2"]}]}
        },
