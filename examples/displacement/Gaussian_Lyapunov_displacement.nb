Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
    RowBox[{"PDF", "[", 
     RowBox[{
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
     "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{"Gaussian", " ", "prior"}], " ", "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"likelihood", "[", 
     RowBox[{"\[Theta]_", ",", "x_", ",", "x0_"}], "]"}], ":=", 
    RowBox[{"PDF", "[", 
     RowBox[{
      RowBox[{"NormalDistribution", "[", 
       RowBox[{
        RowBox[{"x0", "+", "\[Theta]"}], ",", "Vxx"}], "]"}], ",", "x"}], 
     "]"}]}], ";"}], 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Gaussian", " ", "likelihood", " ", "of", " ", "x"}], "-", 
