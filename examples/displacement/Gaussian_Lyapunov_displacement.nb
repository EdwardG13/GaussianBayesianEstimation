    RowBox[{
     RowBox[{"3", " ", 
      SuperscriptBox["Vpp", "2"]}], "+", 
     RowBox[{"6", " ", "Vpp", " ", 
      SuperscriptBox["p0", "2"]}], "+", 
     SuperscriptBox["p0", "4"]}]}], "\[IndentingNewLine]", 
