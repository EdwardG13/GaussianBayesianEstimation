        RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], " ", ";"}], "\n", 
   RowBox[{
    RowBox[{"avgp2", "=", 
     RowBox[{"Vpp", "+", 
      SuperscriptBox["p0", "2"]}]}], " ", ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Second", " ", "moments", " ", "of", " ", 
      RowBox[{"rho0", ".", " ", "For"}], " ", "a", " ", "Gaussian"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"<", 
       SuperscriptBox["X", "4"], ">"}], " ", "=", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["\[Sigma]", "2"]}], "+", 
       RowBox[{"6", " ", 
        SuperscriptBox["\[Sigma]", "2"], " ", 
