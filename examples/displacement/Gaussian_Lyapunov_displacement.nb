            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"x0", "+", "\[Theta]"}], ")"}], "3"], "+", 
            RowBox[{"3", "*", 
             RowBox[{"(", 
              RowBox[{"x0", "+", "\[Theta]"}], ")"}], "*", "Vxx"}]}]}], ",", 
          RowBox[{
           SuperscriptBox["x", "2"], "->", 
           RowBox[{
            SuperscriptBox[
             RowBox[{"(", 
              RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"], "+", "Vxx"}]}], ",", 
          RowBox[{"x", "->", 
