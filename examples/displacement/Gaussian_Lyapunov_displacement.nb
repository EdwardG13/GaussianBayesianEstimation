Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Means", ":", " ", 
      RowBox[{"<", "x", 
       SubscriptBox[">", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", "\[Theta]", ")"}]}]]}]}], "=", 
     RowBox[{
      SubscriptBox["x", "0"], "+", "theta"}]}], ",", " ", 
    RowBox[{
     RowBox[{"<", "p", 
      SubscriptBox[">", 
       RowBox[{"\[Rho]", 
        RowBox[{"(", "\[Theta]", ")"}]}]]}], "=", 
     RowBox[{
      SubscriptBox["p", "0"], " ", "and", " ", "a", " ", "diagonal", " ", 
      "covariance", " ", "matrix", " ", "V"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
      "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Gaussian", " ", "prior"}], " ", "*)"}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"First", " ", "moments", " ", "of", " ", "rho0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"avgx", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{"x0", "+", "\[Theta]"}], ")"}], " ", 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], " ", "\n", 
   RowBox[{"avgp", "=", "p0"}], " ", "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Second", " ", "moments", " ", "of", " ", "rho0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"avgx2\[Rho]0", "=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Vxx", "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}], ")"}], " ", 
        RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}], "//", "Simplify"}]}], "\n", 
   RowBox[{"avgp2\[Rho]0", "=", 
    RowBox[{"Vpp", "+", 
     SuperscriptBox["p0", "2"]}]}], "\n", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Fourth", " ", "moments", " ", "of", " ", 
      RowBox[{"rho0", ".", " ", "For"}], " ", "a", " ", "Gaussian"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"<", 
       SuperscriptBox["X", "4"], ">"}], " ", "=", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["\[Sigma]", "2"]}], "+", 
       RowBox[{"6", " ", 
        SuperscriptBox["\[Sigma]", "2"], " ", 
        SuperscriptBox["\[Mu]", "2"]}], " ", "+", " ", 
       SuperscriptBox["\[Mu]", "4"]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"avgx4\[Rho]0", "=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"3", " ", 
           SuperscriptBox["Vxx", "2"]}], "+", 
          RowBox[{"6", " ", "Vxx", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x0", "+", "\[Theta]"}], ")"}], "4"]}], ")"}], " ", 
        RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}], "//", "Simplify"}]}], "\n", 
   RowBox[{"avgp4\[Rho]0", "=", 
    RowBox[{
     RowBox[{"3", " ", 
      SuperscriptBox["Vpp", "2"]}], "+", 
     RowBox[{"6", " ", "Vpp", " ", 
      SuperscriptBox["p0", "2"]}], "+", 
     SuperscriptBox["p0", "4"]}]}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{
      RowBox[{"Cross", " ", "moment"}], " ", "<", 
      RowBox[{
       SuperscriptBox["x", "2"], " ", 
       SuperscriptBox["p", "2"]}], 
      SubscriptBox[">", 
       RowBox[{"\[Rho]", 
        RowBox[{"(", "\[Theta]", ")"}]}]]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["V", "xx"], "+", 
         SuperscriptBox[
          RowBox[{"(", 
           RowBox[{
            SubscriptBox["x", "0"], "+", "\[Theta]"}], ")"}], "2"]}], ")"}], 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["V", "pp"], "+", 
         SuperscriptBox[
          SubscriptBox["p", "0"], "2"]}], ")"}]}], "-", 
      RowBox[{
       FractionBox["1", "2"], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"the", " ", "-", 
          RowBox[{
           FractionBox["1", "2"], " ", "comes", " ", "from", " ", "the", " ", 
           RowBox[{"commutator", "[", 
            RowBox[{"x", ",", "p"}], "]"}]}]}], "=", 
         RowBox[{"i", " ", "via", " ", "Weyl", " ", "ordering"}]}], 
        ")"}]}]}]}], "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"avgx2p2\[Rho]0", "=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"Vxx", "+", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}], ")"}], 
           RowBox[{"(", 
            RowBox[{"Vpp", "+", 
             SuperscriptBox["p0", "2"]}], ")"}]}], "-", 
          FractionBox["1", "2"]}], ")"}], " ", 
        RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}], "//", "Simplify"}]}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Gram", " ", "matrix", " ", "elements", " ", 
      SubscriptBox["G", "ij"]}], " ", "=", 
     RowBox[{"<", 
      RowBox[{
       SubscriptBox["\[CapitalDelta]B", "i"], " ", 
       SubscriptBox["\[CapitalDelta]B", "j"]}], 
      SubscriptBox[">", 
       SubscriptBox["\[Rho]", "0"]]}]}], "*)"}], "\n", "\[IndentingNewLine]", 
   RowBox[{"GxxLin", "=", 
    RowBox[{"avgx2\[Rho]0", "-", 
     SuperscriptBox["avgx", "2"]}]}], "\n", 
   RowBox[{"GppLin", "=", 
    RowBox[{"avgp2\[Rho]0", "-", 
     SuperscriptBox["avgp", "2"]}]}], "\n", 
   RowBox[{"GxpLin", "=", "0"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"GxxQuad", "=", 
    RowBox[{
     RowBox[{"avgx4\[Rho]0", "-", 
      SuperscriptBox["avgx2\[Rho]0", "2"]}], "//", "Simplify"}]}], "\n", 
   RowBox[{"GppQuad", "=", 
    RowBox[{
     RowBox[{"avgp4\[Rho]0", "-", 
      SuperscriptBox["avgp2\[Rho]0", "2"]}], "//", "Simplify"}]}], "\n", 
   RowBox[{"GxpQuad", "=", 
    RowBox[{
     RowBox[{"avgx2p2\[Rho]0", "-", 
      RowBox[{"avgx2\[Rho]0", "*", "avgp2\[Rho]0"}]}], "//", "Simplify"}]}], 
   "\n", "\[IndentingNewLine]", 
   RowBox[{"GxpQuad", "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       FractionBox["1", "4"], 
       RowBox[{"(", 
        RowBox[{
         RowBox[{
          RowBox[{"(", "avgx2\[Rho]0", ")"}], 
          RowBox[{"(", "avgp2\[Rho]0", ")"}]}], "+", 
         FractionBox["1", "2"]}], ")"}]}], "-", 
      RowBox[{
       FractionBox["1", "4"], 
       RowBox[{"(", 
        RowBox[{"avgx2\[Rho]0", " ", "avgp2\[Rho]0"}], ")"}]}]}], "//", 
     "Simplify"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Full", " ", "6", "x6", " ", "Gram", " ", "matrix", " ", 
     RowBox[{"(", 
      RowBox[{"block", " ", 
       RowBox[{"diagonal", ":", 
        RowBox[{"1", "|", 
         RowBox[{"2", "x2", " ", "linear"}], "|", 
         RowBox[{"3", "x3", " ", "quadratic"}]}]}]}], ")"}]}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"Gmat", "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0", ",", "0", ",", "0", ",", "0"}], 
         "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "GxxLin", ",", "0", ",", "0", ",", "0", ",", "0"}],
          "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "GppLin", ",", "0", ",", "0", ",", "0"}],
          "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
         "0", ",", "0", ",", "0", ",", "GxxQuad", ",", "0", ",", "GxpQuad"}], 
         "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
         "0", ",", "0", ",", "0", ",", "0", ",", "GxpQuad", ",", "0"}], "}"}],
         ",", 
        RowBox[{"{", 
         RowBox[{
         "0", ",", "0", ",", "0", ",", "GxpQuad", ",", "0", ",", "GppQuad"}], 
         "}"}]}], "}"}], "//", "Simplify"}]}], ";"}], "\n", 
