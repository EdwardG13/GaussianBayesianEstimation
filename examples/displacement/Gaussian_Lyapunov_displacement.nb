Cell["\<\
Showing that the posterior mean for uniform prior only contains odd powers of \
x\
\>", "Section",
 CellChangeTimes->{{3.9800641916158295`*^9, 3.9800641997729607`*^9}, 
   3.9821318203727875`*^9, {3.9821354050378075`*^9, 3.9821354289465313`*^9}, {
