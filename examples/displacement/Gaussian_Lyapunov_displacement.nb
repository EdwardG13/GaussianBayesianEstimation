   3.982398199790819*^9, 3.9825976438692207`*^9, 3.9825979209944096`*^9},
 CellLabel->"Out[31]=",ExpressionUUID->"5498f7ee-9bb6-1e43-aa53-d4bc26481e43"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
    RowBox[{
    "Now", " ", "calculate", " ", "the", " ", "constrained", " ", "MSL", " ", 
     "\[ScriptCapitalL]", 
     RowBox[{"(", 
      SubscriptBox["\[ScriptCapitalS]", "\[ScriptCapitalV]"], ")"}]}], "=", 
    RowBox[{"\[Lambda]", "-", 
     RowBox[{
      SuperscriptBox["b", "T"], 
      SuperscriptBox["G", 
       RowBox[{"-", "1"}]], "b"}]}]}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"\[Lambda]", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       SuperscriptBox["\[Theta]", "2"], " ", 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "  ", 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Lambda]", "-", 
     RowBox[{"bvec", ".", 
      RowBox[{"Inverse", "[", "Gmat", "]"}], ".", "bvec"}]}], "//", 
    "Simplify"}]}]}]], "Input",
 CellChangeTimes->{{3.9829095336964607`*^9, 3.9829095775354824`*^9}, {
  3.982909621408247*^9, 3.9829096221898766`*^9}, {3.982909949142729*^9, 
  3.9829099949529305`*^9}},
 CellLabel->"In[42]:=",ExpressionUUID->"8c738acb-eac9-cf42-b34a-68f36d635078"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[Mu]0", "2"], "+", 
  SuperscriptBox["\[Sigma]0", "2"]}]], "Output",
 CellChangeTimes->{{3.9829095467012043`*^9, 3.9829095785342197`*^9}, 
   3.982909622998207*^9, 3.9829099957341805`*^9, 3.982910052220751*^9},
 CellLabel->"Out[42]=",ExpressionUUID->"a43f10bf-13f9-2440-a710-f3358516ae08"],

Cell[BoxData[
 RowBox[{
  SuperscriptBox["\[Sigma]0", "2"], "-", 
  FractionBox[
   RowBox[{"8", " ", "Vpp", " ", 
    RowBox[{"(", 
     RowBox[{
      RowBox[{"2", " ", 
       SuperscriptBox["p0", "2"]}], "+", "Vpp"}], ")"}], " ", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"x0", "+", "\[Mu]0"}], ")"}], "2"], " ", 
    SuperscriptBox["\[Sigma]0", "4"]}], 
   RowBox[{
    RowBox[{"-", 
     FractionBox["1", "4"]}], "+", 
    RowBox[{"2", " ", "Vpp", " ", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"2", " ", 
        SuperscriptBox["p0", "2"]}], "+", "Vpp"}], ")"}], " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["p0", "4"], "+", 
       RowBox[{"6", " ", 
        SuperscriptBox["p0", "2"], " ", "Vpp"}], "+", 
       RowBox[{"3", " ", 
        SuperscriptBox["Vpp", "2"]}], "-", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Vxx", "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x0", "+", "\[Mu]0"}], ")"}], "2"], "+", 
          SuperscriptBox["\[Sigma]0", "2"]}], ")"}], "2"]}], 
      ")"}]}]}]]}]], "Output",
 CellChangeTimes->{{3.9829095467012043`*^9, 3.9829095785342197`*^9}, 
   3.982909622998207*^9, 3.9829099957341805`*^9, 3.982910052284067*^9},
 CellLabel->"Out[43]=",ExpressionUUID->"87a4470f-93fe-6e48-a0a6-012830ee6809"]
}, Open  ]]
}, Closed]],

Cell[CellGroupData[{

Cell["\<\
Symmetric logarithmic derivative (SLD) and Quantum Fisher Information (QFI) \
\>", "Section",
 CellChangeTimes->{{3.6520949429746923`*^9, 3.652094951849272*^9}, {
  3.9829995552445393`*^9, 
  3.9829995690024567`*^9}},ExpressionUUID->"5dd265b7-a003-df40-b2fe-\
bed7f8b2a27d"],

Cell[TextData[{
 "We want to obtain the symmetric logarithmic derivative. For a Gaussian \
state, it is a quadratic form of position and momentum (",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "ae0e481a-1b58-3f45-9408-5879a7fa7039"],
 " and ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "95bf9fd1-f4c5-a247-8f7a-ade0bb28f2cd"],
 ") \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", "ij"], " ", 
      RowBox[{
       SubscriptBox["L", "ij"], " ", 
       FractionBox["1", "2"], 
       SubscriptBox[
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           SubscriptBox["R", "i"], "-", 
           SubscriptBox["d", "i"]}], ",", 
          RowBox[{
           SubscriptBox["R", "j"], "-", 
           SubscriptBox["d", "j"]}]}], "}"}], "+"]}]}], "+", 
     RowBox[{
      SubscriptBox["\[Sum]", "i"], 
      RowBox[{
       SubscriptBox["b", "i"], "(", 
       RowBox[{
        SubscriptBox["R", "i"], "-", 
        SubscriptBox["d", "i"]}], ")"}]}], "-", 
     RowBox[{
      FractionBox["1", "2"], "tr", 
      RowBox[{"{", 
       StyleBox[
        RowBox[{"L", " ", "\[CapitalGamma]"}],
        FontWeight->"Bold"], "}"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "6732dfb8-5b9e-7d44-a862-1ae7ae6f4565"],
 ",\n\nhere, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], "=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox["R", "i"], "\[RightAngleBracket]"}], "=", 
     RowBox[{"tr", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["R", "i"], "\[Rho]"}], "}"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"21bbe35b-c416-f34f-b3e6-8f664207c01a"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["R", "\[Rule]"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "p"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "c6ae58c8-c302-e048-91af-b2ade09280bd"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["\[CapitalGamma]",
     FontWeight->"Bold"], "=", 
    RowBox[{"2", 
     StyleBox["\[Sigma]",
      FontWeight->"Bold"]}]}], TraditionalForm]],ExpressionUUID->
  "1bd645c3-47b3-de41-bc92-f3967ef4766d"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Sigma]", "ij"], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox[
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["R", "i"], ",", 
         SubscriptBox["R", "j"]}], "}"}], "+"], "\[RightAngleBracket]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"0fe758e5-038b-2f45-be2c-1e2440e5c916"],
 " are the elements of the (symmetrized) covariance matrix. See Monras (2013) \
https://arxiv.org/pdf/1303.3682."
}], "Text",
 CellChangeTimes->{{3.6522528959283752`*^9, 3.6522528997803583`*^9}, {
  3.652252984348523*^9, 3.652252986882021*^9}, {3.9817898712708893`*^9, 
  3.981789900635914*^9}},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"b968d6e2-cd05-0c4a-8660-27792d6d7843"],

Cell[TextData[{
 "Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["\[CapitalOmega]",
     FontWeight->"Bold"], "=", 
    RowBox[{"(", GridBox[{
       {"0", 
        RowBox[{"-", "1"}]},
       {"1", "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "15c64565-660e-ef40-b878-7a1c0a475fe0"],
 " is the symplectic matrix. \n\nThe coefficients are given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["L",
     FontWeight->"Bold"], "=", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["\[ScriptCapitalD]", 
       StyleBox["\[CapitalGamma]",
        FontWeight->"Bold"]], 
      RowBox[{"-", "1"}]], "(", 
     RowBox[{"\[PartialD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "6945dc01-d132-2d44-97f6-b306023eba52"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["b", "\[Rule]"], "=", 
    RowBox[{"2", 
     SuperscriptBox[
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"], 
      RowBox[{"-", "1"}]], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["d", "\[Rule]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "624b11e3-6acd-6b45-acb1-35855c4c1da7"],
 ".\n\nFor displacements encoded in the mean of the Wigner function, \
\[PartialD]\[CapitalGamma]=0 and so the SLD is linear in the quadratures."
}], "Text",
 CellChangeTimes->{{3.652253037031055*^9, 3.6522530522470703`*^9}, {
   3.6522532310445347`*^9, 3.6522532336786747`*^9}, 3.652254652824998*^9, {
   3.9816108863991127`*^9, 3.981610887282446*^9}, {3.9817899058560505`*^9, 
   3.981789906638445*^9}, {3.9829288775514107`*^9, 3.9829289192942467`*^9}},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"8497633f-3a2b-634a-94f6-11c36e77fa73"],

Cell[TextData[{
 "The linear term ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["b", "\[Rule]"], "=", 
    RowBox[{"2", 
     SuperscriptBox[
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"], 
      RowBox[{"-", "1"}]], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["d", "\[Rule]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "1a72533c-993e-994a-b476-3dad29362f32"],
 " is"
}], "Text",
 CellChangeTimes->{{3.652254974177588*^9, 3.6522550474156857`*^9}, {
   3.652255231268901*^9, 3.6522552671706247`*^9}, 3.9816101486663265`*^9, {
   3.981612587475075*^9, 3.981612600882477*^9}},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"a130e310-a0fa-4441-9b1a-fc39a1b2d7b7"],

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"covDisplacement", "=", 
    TagBox[
     RowBox[{"(", "\[NoBreak]", GridBox[{
        {"Vxx", "0"},
        {"0", "Vpp"}
       },
       GridBoxAlignment->{"Columns" -> {{Center}}, "Rows" -> {{Baseline}}},
       GridBoxSpacings->{"Columns" -> {
           Offset[0.27999999999999997`], {
            Offset[0.7]}, 
           Offset[0.27999999999999997`]}, "Rows" -> {
           Offset[0.2], {
            Offset[0.4]}, 
           Offset[0.2]}}], "\[NoBreak]", ")"}],
     Function[BoxForm`e$, 
      MatrixForm[BoxForm`e$]]]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Covariance", " ", "matrix"}], "*)"}], "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"\[CapitalGamma]", "=", 
    RowBox[{"2", "*", "covDisplacement"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{
   "Monras", " ", "uses", " ", "a", " ", "different", " ", "notation", " ", 
    "with", " ", "a", " ", "factor", " ", "of", " ", "2"}], " ", "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"d", "[", "\[Theta]_", "]"}], ":=", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"x0", "+", "\[Theta]"}], ",", "p0"}], "}"}]}], ";"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Mean", " ", "of", " ", "Wigner", " ", "function"}], "*)"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dd", "=", 
   RowBox[{"D", "[", 
    RowBox[{
     RowBox[{"d", "[", "\[Theta]", "]"}], ",", "\[Theta]"}], "]"}]}], 
  ";"}], "\[IndentingNewLine]"}], "Input",
 CellChangeTimes->{{3.9829291018688297`*^9, 3.9829293559200325`*^9}},
 CellLabel->"In[54]:=",ExpressionUUID->"8fed3ca3-67e7-6f4d-8192-9c3f924e55d3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"b", "=", 
  RowBox[{
   RowBox[{"2", "*", 
    RowBox[{
     RowBox[{"Inverse", "[", "\[CapitalGamma]", "]"}], ".", "dd"}]}], "//", 
   "FullSimplify"}]}]], "Input",
 CellChangeTimes->{{3.981609983002611*^9, 3.981610028835531*^9}, {
   3.9816124921333504`*^9, 3.98161253468598*^9}, {3.981612613919012*^9, 
   3.981612614458496*^9}, 3.982929201357046*^9, {3.982929359144129*^9, 
   3.9829293630293713`*^9}, {3.9829296319429092`*^9, 3.9829296321232605`*^9}},
 CellLabel->"In[58]:=",ExpressionUUID->"3db74043-d1f1-9044-b52b-e800d326f25c"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   FractionBox["1", "Vxx"], ",", "0"}], "}"}]], "Output",
 CellChangeTimes->{{3.981610008549238*^9, 3.981610029106619*^9}, 
   3.9816124927110806`*^9, 3.9816125349220486`*^9, 3.9816126146989365`*^9, 
   3.982912475929775*^9, 3.9829288622963467`*^9, 3.982929150668457*^9, 
   3.982929363422695*^9, 3.9829296327740345`*^9, 3.9829905006131573`*^9},
 CellLabel->"Out[58]=",ExpressionUUID->"7c00d441-004f-6241-a0b2-b03d51d3ea0e"]
}, Open  ]],

Cell[TextData[{
 "The constant term is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", "2"]}], "tr", 
     RowBox[{"{", 
      RowBox[{
       StyleBox["L",
        FontWeight->"Bold"], " ", 
       StyleBox["\[CapitalGamma]",
        FontWeight->"Bold"]}], "}"}]}], "=", "0"}], TraditionalForm]],
  ExpressionUUID->"d5449ab2-2394-0b4b-a3b9-8141c1c3ecdf"],
 " since the quadratic ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["L",
     FontWeight->"Bold"], " "}], TraditionalForm]],ExpressionUUID->
  "8e6efff9-6748-a24e-8188-6c1e52822588"],
 "=0. "
}], "Text",
 CellChangeTimes->{{3.652254974177588*^9, 3.6522550474156857`*^9}, {
   3.652255231268901*^9, 3.6522552671706247`*^9}, 3.9816101486663265`*^9, {
   3.982912864094631*^9, 3.982912869821932*^9}, 3.982928962452503*^9, {
   3.9829905905967216`*^9, 3.982990620445513*^9}},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"1b6005b9-c08e-8346-8013-283fc1a3418e"],

Cell[TextData[{
 "The QFI is then ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Tr", "(", 
    RowBox[{
     RowBox[{"\[Rho]", "(", "\[Theta]", ")"}], 
     SuperscriptBox["\[ScriptCapitalL]", "2"]}], ")"}], TraditionalForm]],
  ExpressionUUID->"80f519b7-aea5-3c45-baf7-e5b239edaf57"]
}], "Text",
 CellChangeTimes->{{3.652254974177588*^9, 3.6522550474156857`*^9}, {
   3.652255231268901*^9, 3.6522552671706247`*^9}, 3.9816101486663265`*^9, {
   3.981612587475075*^9, 3.981612600882477*^9}, {3.9829290377500744`*^9, 
   3.9829290560356503`*^9}, {3.9829293853175716`*^9, 
   3.9829293853175716`*^9}, {3.9829298261147575`*^9, 
   3.9829298449455566`*^9}, {3.9829906294393787`*^9, 3.982990639257551*^9}},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"4f355f0b-d8f9-b24f-a905-40170dc112ef"],

Cell[BoxData[
 RowBox[{"Clear", "[", 
  RowBox[{"x", ",", "p"}], "]"}]], "Input",
 CellChangeTimes->{{3.9829296724767227`*^9, 3.9829296835677814`*^9}},
 CellLabel->"In[60]:=",ExpressionUUID->"6c54c6be-8f6e-b343-b964-89c3ecb45d74"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Expand", "[", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"b", ".", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"x", ",", "p"}], "}"}], "-", 
         RowBox[{"d", "[", "\[Theta]", "]"}]}], ")"}]}], ")"}], "2"], "]"}], "/.", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      SuperscriptBox["x", "2"], "->", 
      RowBox[{"Vxx", "+", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}]}], ",", 
     RowBox[{"x", "->", 
      RowBox[{"x0", "+", "\[Theta]"}]}]}], "}"}]}], "//", 
  "Simplify"}]], "Input",
 CellChangeTimes->{{3.982929648050144*^9, 3.9829297755135612`*^9}, 
   3.982990508874769*^9, {3.98299064289571*^9, 3.982990658898636*^9}},
 CellLabel->"In[65]:=",ExpressionUUID->"e86b00bf-40b0-1946-be71-95711fba79df"],

Cell[BoxData[
 FractionBox["1", "Vxx"]], "Output",
 CellChangeTimes->{{3.98292969300634*^9, 3.982929722559534*^9}, {
   3.9829297554893417`*^9, 3.982929775974695*^9}, 3.982990505514843*^9, {
   3.982990645845047*^9, 3.9829906660612564`*^9}},
 CellLabel->"Out[65]=",ExpressionUUID->"3d6982f7-2665-c74d-beca-55a0948a42b1"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Series", "[", 
   RowBox[{
    FractionBox[
     RowBox[{"Vxx", " ", 
      SuperscriptBox["\[Sigma]0", "2"]}], 
     RowBox[{"Vxx", "+", 
      SuperscriptBox["\[Sigma]0", "2"]}]], ",", 
    RowBox[{"{", 
     RowBox[{"\[Sigma]0", ",", "0", ",", "4"}], "}"}]}], "]"}], " ", 
  RowBox[{"(*", " ", 
   RowBox[{"Compare", " ", "to", " ", "MSL", " ", "for", " ", "small", " ", 
    SubscriptBox["\[Sigma]", "0"]}], "*)"}]}]], "Input",
 CellChangeTimes->{{3.982929451537094*^9, 3.982929463241728*^9}, {
  3.9829298543999577`*^9, 
  3.9829298982580833`*^9}},ExpressionUUID->"cb7b77aa-7c9f-6245-8678-\
d6e0d9c20152"],

Cell[BoxData[
 InterpretationBox[
  RowBox[{
   SuperscriptBox["\[Sigma]0", "2"], "-", 
   FractionBox[
    SuperscriptBox["\[Sigma]0", "4"], "Vxx"], "+", 
   InterpretationBox[
    SuperscriptBox[
     RowBox[{"O", "[", "\[Sigma]0", "]"}], "5"],
    SeriesData[$CellContext`\[Sigma]0, 0, {}, 2, 5, 1],
    Editable->False]}],
  SeriesData[$CellContext`\[Sigma]0, 0, {1, 0, (-1)/$CellContext`Vxx}, 2, 5, 
   1],
  Editable->False]], "Output",
