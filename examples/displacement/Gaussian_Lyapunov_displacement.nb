Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Means", ":", " ", 
      RowBox[{"<", "x", 
       SubscriptBox[">", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", "\[Theta]", ")"}]}]]}]}], "=", 
     RowBox[{
      SubscriptBox["x", "0"], "+", "theta"}]}], ",", " ", 
    RowBox[{
     RowBox[{"<", "p", 
      SubscriptBox[">", 
       RowBox[{"\[Rho]", 
        RowBox[{"(", "\[Theta]", ")"}]}]]}], "=", 
     RowBox[{
      SubscriptBox["p", "0"], " ", "and", " ", "a", " ", "diagonal", " ", 
      "covariance", " ", "matrix", " ", "V"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
      "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Gaussian", " ", "prior"}], " ", "*)"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"First", " ", "moments", " ", "of", " ", "rho0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avgx2", "=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Vxx", "+", 
          SuperscriptBox[
           RowBox[{"(", 
            RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}], ")"}], " ", 
        RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], " ", ";"}], "\n", 
   RowBox[{
    RowBox[{"avgp2", "=", 
     RowBox[{"Vpp", "+", 
      SuperscriptBox["p0", "2"]}]}], " ", ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
     RowBox[{"Second", " ", "moments", " ", "of", " ", 
      RowBox[{"rho0", ".", " ", "For"}], " ", "a", " ", "Gaussian"}], ",", 
     " ", 
     RowBox[{
      RowBox[{"<", 
       SuperscriptBox["X", "4"], ">"}], " ", "=", 
      RowBox[{
       RowBox[{"3", " ", 
        SuperscriptBox["\[Sigma]", "2"]}], "+", 
       RowBox[{"6", " ", 
        SuperscriptBox["\[Sigma]", "2"], " ", 
        SuperscriptBox["\[Mu]", "2"]}], " ", "+", " ", 
       SuperscriptBox["\[Mu]", "4"]}]}]}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"avgx4\[Rho]0", "=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{"3", " ", 
           SuperscriptBox["Vxx", "2"]}], "+", 
          RowBox[{"6", " ", "Vxx", " ", 
           SuperscriptBox[
            RowBox[{"(", 
             RowBox[{"x0", "+", "\[Theta]"}], ")"}], "2"]}], "+", 
          SuperscriptBox[
           RowBox[{"(", 
