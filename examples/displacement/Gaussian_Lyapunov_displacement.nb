Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
    RowBox[{
     RowBox[{"Means", ":", " ", 
      RowBox[{"<", "x", 
       SubscriptBox[">", 
        RowBox[{"\[Rho]", 
         RowBox[{"(", "\[Theta]", ")"}]}]]}]}], "=", 
     RowBox[{
      SubscriptBox["x", "0"], "+", "theta"}]}], ",", " ", 
    RowBox[{
     RowBox[{"<", "p", 
      SubscriptBox[">", 
       RowBox[{"\[Rho]", 
        RowBox[{"(", "\[Theta]", ")"}]}]]}], "=", 
     RowBox[{
      SubscriptBox["p", "0"], " ", "and", " ", "a", " ", "diagonal", " ", 
      "covariance", " ", "matrix", " ", "V"}]}]}], "*)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
      "]"}]}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Gaussian", " ", "prior"}], " ", "*)"}], "\[IndentingNewLine]", 
   "\n", 
   RowBox[{"(*", 
    RowBox[{"First", " ", "moments", " ", "of", " ", "rho0"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"avgx2", "=", 
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{"Vxx", "+", 
          SuperscriptBox[
           RowBox[{"(", 
