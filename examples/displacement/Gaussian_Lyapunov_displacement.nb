Cell[TextData[{
 "Basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "\[CapitalDelta]x", ",", 
     SuperscriptBox["\[CapitalDelta]x", "3"]}]}], TraditionalForm]],
  ExpressionUUID->"ecf73ef8-bfde-2840-bd3b-f9d6cbd0f52b"],
 "} with uniform prior (shows improvement)"
}], "Section",
 CellChangeTimes->{{3.9800641916158295`*^9, 3.9800641997729607`*^9}, 
   3.9821318203727875`*^9, {3.9821354050378075`*^9, 3.9821354289465313`*^9}, {
