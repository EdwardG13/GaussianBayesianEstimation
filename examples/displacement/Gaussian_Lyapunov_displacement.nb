6c9124040c32"],

Cell[TextData[{
 "Basis ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["B", "i"], TraditionalForm]],ExpressionUUID->
  "a23c4946-4955-394a-b4e0-9a7b3624e693"],
 " is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "\[CapitalDelta]x", ",", 
     SuperscriptBox["\[CapitalDelta]x", "3"]}]}], TraditionalForm]],
  ExpressionUUID->"da6a1bc3-01e5-2e43-85df-044ad73335c4"],
 "} where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]x", "=", 
    RowBox[{
     OverscriptBox["x", "^"], "-", 
     SubscriptBox[
      RowBox[{"\[LeftAngleBracket]", "x", "\[RightAngleBracket]"}], 
      SubscriptBox["\[Rho]", "0"]]}]}], TraditionalForm]],ExpressionUUID->
  "976be984-5de1-b447-a338-4723ed7b0f4c"],
 ".\n\nIt turns out that this has the same MSL as the basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", 
    RowBox[{"1", ",", "\[CapitalDelta]x"}]}], TraditionalForm]],
  ExpressionUUID->"6c90436d-1b66-9346-9d67-95c6a2ee7f52"],
 "}, which implies that ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalDelta]x", "2"], TraditionalForm]],ExpressionUUID->
  "15a21959-30cf-7849-9abb-4f09427ae58c"],
 " is not included in the posterior mean.i d"
}], "Text",
