          FractionBox["\[CapitalDelta]", "2"]}]}], "}"}], ",", 
       RowBox[{"Assumptions", "->", 
        RowBox[{"\[CapitalDelta]", ">", "0"}]}]}], "]"}]}], " ", ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"Gx3", "=", 
    RowBox[{
     RowBox[{"Integrate", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"(", 
