            RowBox[{"x0", "+", "\[Theta]"}], ")"}]}]}], "}"}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Theta]", ",", 
         RowBox[{"\[Mu]0", "-", 
          FractionBox["\[CapitalDelta]", "2"]}], ",", 
