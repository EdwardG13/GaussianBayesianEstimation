Cell[BoxData[
 RowBox[{
  RowBox[{"InfoGainSqueezedDisplaced", "[", 
   RowBox[{
   "\[Mu]0_", ",", "\[Sigma]0_", ",", "\[Mu]_", ",", "\[Phi]_", ",", "r_"}], 
   "]"}], "=", 
  RowBox[{
   RowBox[{
    RowBox[{"\[Lambda]", "-", "MSL"}], "/.", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"Vxx", "->", 
       RowBox[{"Exp", "[", 
        RowBox[{"2", "r"}], "]"}]}], ",", 
      RowBox[{"Vpp", "->", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "2"}], "r"}], "]"}]}], ",", 
