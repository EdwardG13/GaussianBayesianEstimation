Cell[TextData[{
 "Use the quadratic centred basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"{", 
     RowBox[{"1", ",", 
      SuperscriptBox["\[CapitalDelta]x", "2"], ",", 
      SuperscriptBox["\[CapitalDelta]p", "2"]}]}]}], TraditionalForm]],
  ExpressionUUID->"7f7d8355-d217-5346-b8de-0e0de1a2a343"],
 "} with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]x", "2"], "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["x", "^"], "2"], "-", 
     RowBox[{"Tr", "(", 
      RowBox[{
       SubscriptBox["\[Rho]", "0"], 
       SuperscriptBox[
        OverscriptBox["x", "^"], "2"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"43c8a5b7-54db-d448-aa11-88121b1191e0"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalDelta]p", "2"], "=", 
    RowBox[{
     SuperscriptBox[
      OverscriptBox["p", "^"], "2"], "-", 
     RowBox[{"Tr", "(", 
      RowBox[{
       SubscriptBox["\[Rho]", "0"], 
       SuperscriptBox[
        OverscriptBox["p", "^"], "2"]}], ")"}]}]}], TraditionalForm]],
  ExpressionUUID->"e69d87c0-0d07-0b42-96d5-35fe1f5a1fd1"]
}], "Text",
