  0.94, 0.91, 0.88],ExpressionUUID->"912331ed-3fab-d040-8393-2a56f1acb017"],

Cell[BoxData[
 RowBox[{
  RowBox[{"covSqueezed", "[", "\[Theta]_", "]"}], ":=", 
  RowBox[{"(", GridBox[{
     {
      RowBox[{"Vxx", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Theta]"}], "]"}]}], "0"},
     {"0", 
      RowBox[{"Vpp", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"2", "\[Theta]"}], "]"}]}]}
    }], ")"}]}]], "Input",
 CellChangeTimes->{{3.981609611400915*^9, 3.981609675665804*^9}, {
  3.9816109359989243`*^9, 3.9816109367040615`*^9}},
 CellLabel->
  "In[153]:=",ExpressionUUID->"ae4f24bd-cbea-4b4c-97b8-3a820d199a84"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"mL", "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{"L", "[", 
        RowBox[{"1", ",", "1"}], "]"}], 
       RowBox[{"L", "[", 
        RowBox[{"1", ",", "2"}], "]"}]},
      {
       RowBox[{"L", "[", 
        RowBox[{"2", ",", "1"}], "]"}], 
       RowBox[{"L", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]", "=", 
   RowBox[{"2", 
    RowBox[{"covSqueezed", "[", "\[Theta]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[CapitalGamma]", "=", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"covSqueezed", "[", "\[Theta]", "]"}]}], ",", "\[Theta]"}], 
     "]"}], "//", "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=", 
   RowBox[{"(", GridBox[{
      {"0", 
       RowBox[{"-", "1"}]},
      {"1", "0"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "=", 
   RowBox[{
    RowBox[{"Transpose", "[", "\[CapitalOmega]", "]"}], ".", 
    "\[CapitalGamma]"}]}], ";"}]}], "Input",
 CellChangeTimes->{{3.652253611555421*^9, 3.652253682247488*^9}, {
  3.652253722358612*^9, 3.652253756821752*^9}, {3.652253844812969*^9, 
