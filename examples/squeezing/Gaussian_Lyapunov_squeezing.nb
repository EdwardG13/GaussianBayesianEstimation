Cell[TextData[{
 "Note that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["Y",
      FontWeight->"Bold"], 
     StyleBox["-",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox["F",
       FontWeight->"Bold"], 
      StyleBox[" ",
       FontWeight->"Bold"], 
      StyleBox["Y",
       FontWeight->"Bold"], 
      StyleBox[" ",
       FontWeight->"Bold"], 
      SuperscriptBox[
       StyleBox["F",
        FontWeight->"Bold"], "T"]}]}], "=", 
    RowBox[{
     RowBox[{
      StyleBox["-",
       FontWeight->"Bold"], 
      SuperscriptBox[
       StyleBox["\[CapitalOmega]",
        FontWeight->"Bold"], "T"]}], 
     RowBox[{"\[PartialD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]}], 
     StyleBox[" ",
      FontWeight->"Bold"], 
     StyleBox["\[CapitalOmega]",
      FontWeight->"Bold"]}]}], TraditionalForm]],ExpressionUUID->
  "fc55b430-4b9b-3447-bc44-c6b18cc281f9"],
 " is a discrete-time Lyapunov equation, whose solution is formally given by ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["Y",
     FontWeight->"Bold"], " ", "=", " ", 
    RowBox[{"-", 
     RowBox[{
      SubscriptBox["\[Sum]", "k"], 
      RowBox[{
       RowBox[{
        SuperscriptBox[
         StyleBox["F",
          FontWeight->"Bold"], "k"], "(", 
        RowBox[{
         SuperscriptBox[
          StyleBox["\[CapitalOmega]",
           FontWeight->"Bold"], "T"], 
         RowBox[{"\[PartialD]", 
          StyleBox["\[CapitalGamma]",
           FontWeight->"Bold"]}], 
         StyleBox[" ",
          FontWeight->"Bold"], 
         StyleBox["\[CapitalOmega]",
          FontWeight->"Bold"]}], ")"}], 
       RowBox[{
        SuperscriptBox[
         StyleBox["F",
          FontWeight->"Bold"], 
         RowBox[{"T", " ", "k"}]], "."}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"651f7fd4-68f2-394e-973d-6206da023629"],
 " "
}], "Text",
 CellChangeTimes->{{3.65225466084861*^9, 3.6522546980037537`*^9}, 
   3.9829124715893784`*^9},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"84546f1d-ab7b-3346-ab00-4bb0621b1943"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"-", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"MatrixPower", "[", 
          RowBox[{"F", ",", "k"}], "]"}], ".", 
         RowBox[{"Transpose", "[", "\[CapitalOmega]", "]"}], ".", 
         "d\[CapitalGamma]", ".", "\[CapitalOmega]", ".", 
         RowBox[{"MatrixPower", "[", 
          RowBox[{
           RowBox[{"Transpose", "[", "F", "]"}], ",", "k"}], "]"}]}], ",", 
        RowBox[{"Assumptions", "\[Rule]", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"k", "\[Element]", "Integers"}], ",", 
           RowBox[{"k", ">", "0"}]}], "}"}]}]}], "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"k", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], "//", 
   "MatrixForm"}], "//", "TraditionalForm"}]], "Input",
 CellChangeTimes->{{3.652254708529702*^9, 3.652254819280356*^9}},
 CellLabel->
  "In[160]:=",ExpressionUUID->"3e8e394d-8ab8-544a-bea6-5fd95374412e"],

Cell[BoxData[
 FormBox[
