           Part[#, 2]]}& ), "CopiedValueFunction" -> ({
          (Identity[#]& )[
           Part[#, 1]], 
          (Identity[#]& )[
           Part[#, 2]]}& )}}, PlotInteractivity :> True, 
    PlotRange -> {All, All}, PlotRangeClipping -> True, PlotRangePadding -> {{
       Scaled[0.02], 
