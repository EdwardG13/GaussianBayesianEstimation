Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"sol", "=", 
   RowBox[{
    RowBox[{"Solve", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"Flatten", "[", 
           RowBox[{"mL", "-", 
            RowBox[{"F", ".", "mL", ".", 
             RowBox[{"Transpose", "[", "F", "]"}]}]}], "]"}], "\[LeftDoubleBracket]",
           "#", "\[RightDoubleBracket]"}], "\[Equal]", 
         RowBox[{
          RowBox[{"Flatten", "[", 
