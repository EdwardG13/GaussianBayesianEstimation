Cell[BoxData[{
 RowBox[{
  RowBox[{"mL", "=", 
   RowBox[{"(", GridBox[{
      {
       RowBox[{"L", "[", 
        RowBox[{"1", ",", "1"}], "]"}], 
       RowBox[{"L", "[", 
        RowBox[{"1", ",", "2"}], "]"}]},
      {
       RowBox[{"L", "[", 
        RowBox[{"2", ",", "1"}], "]"}], 
       RowBox[{"L", "[", 
        RowBox[{"2", ",", "2"}], "]"}]}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalGamma]", "=", 
   RowBox[{"2", 
    RowBox[{"covSqueezed", "[", "\[Theta]", "]"}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"d\[CapitalGamma]", "=", 
   RowBox[{
    RowBox[{"D", "[", 
     RowBox[{
      RowBox[{"2", 
       RowBox[{"covSqueezed", "[", "\[Theta]", "]"}]}], ",", "\[Theta]"}], 
     "]"}], "//", "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"\[CapitalOmega]", "=", 
   RowBox[{"(", GridBox[{
      {"0", 
       RowBox[{"-", "1"}]},
      {"1", "0"}
     }], ")"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"F", "=", 
   RowBox[{
    RowBox[{"Transpose", "[", "\[CapitalOmega]", "]"}], ".", 
    "\[CapitalGamma]"}]}], ";"}]}], "Input",
