 InterpretationBox[
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{
        RowBox[{"-", "2"}], " ", "\[Mu]0"}]], " ", "Vxx", " ", "\[Mu]p"}], 
     RowBox[{"Vpp", " ", "\[Mu]x"}]]}], "-", 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "\[Mu]0"}]], " ", "\[Mu]p", " ", 
