  0.67, 0.54, 0.42, 
   0.33],ExpressionUUID->"78152682-24f2-c246-811c-7249544bef68"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
    RowBox[{"PDF", "[", 
     RowBox[{
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"First", " ", "moments"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"avgx\[Rho]0", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"\[Mu]x", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", " ", "\[Theta]"}], "]"}], " ", 
     RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgp\[Rho]0", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"\[Mu]p", " ", 
      RowBox[{"Exp", "[", " ", "\[Theta]", "]"}], " ", 
      RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Second", " ", "moments"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"avgx2\[Rho]0", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Vxx", "+", 
       SuperscriptBox["\[Mu]x", "2"]}], ")"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "\[Theta]"}], "]"}], " ", 
     RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgp2\[Rho]0", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Vpp", "+", 
        SuperscriptBox["\[Mu]p", "2"]}], ")"}], " ", 
      RowBox[{"Exp", "[", 
       RowBox[{"2", " ", "\[Theta]"}], "]"}], " ", 
      RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Mixed", " ", "moment"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgxp\[Rho]0", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"\[Mu]x", " ", "\[Mu]p", " ", 
      RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Centered", " ", "Gram", " ", "elements"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Gxx", "=", 
   RowBox[{"avgx2\[Rho]0", "-", 
    SuperscriptBox["avgx\[Rho]0", "2"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"Gpp", "=", 
