 RowBox[{
  RowBox[{"avgp2\[Rho]0", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{"Vpp", "+", 
        SuperscriptBox["\[Mu]p", "2"]}], ")"}], " ", 
