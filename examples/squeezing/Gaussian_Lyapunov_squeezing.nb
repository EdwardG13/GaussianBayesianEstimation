Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Choose", " ", "a", " ", "Gaussian", " ", "prior", " ", "for", " ", 
    "simple", " ", "moments"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
     RowBox[{"PDF", "[", 
      RowBox[{
       RowBox[{"NormalDistribution", "[", 
        RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
     SubscriptBox["\[Rho]", "0"], " ", "averages"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"avgx2\[Rho]0", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"Vxx", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "2"}], " ", "\[Theta]"}], "]"}], " ", 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"avgp2\[Rho]0", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"Vpp", " ", 
       RowBox[{"Exp", "[", 
        RowBox[{"2", " ", "\[Theta]"}], "]"}], " ", 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"avgx4\[Rho]0", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Vxx", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{
            RowBox[{"-", "2"}], " ", "\[Theta]"}], "]"}]}], ")"}], "2"], 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"avgp4\[Rho]0", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{"3", " ", 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{"Vpp", " ", 
          RowBox[{"Exp", "[", 
           RowBox[{"2", " ", "\[Theta]"}], "]"}]}], ")"}], "2"], " ", 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"avgx2p2\[Rho]0", "=", 
    RowBox[{"Integrate", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Vxx", " ", "Vpp"}], "-", 
         FractionBox["1", "2"]}], ")"}], " ", 
       RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Theta]", ",", 
        RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
      RowBox[{"Assumptions", "->", 
       RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Centered", " ", "Gram", " ", "elements"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Gxx", "=", 
     RowBox[{"avgx4\[Rho]0", "-", 
      SuperscriptBox["avgx2\[Rho]0", "2"]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Gpp", "=", 
     RowBox[{"avgp4\[Rho]0", "-", 
      SuperscriptBox["avgp2\[Rho]0", "2"]}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Gxp", "=", 
     RowBox[{"avgx2p2\[Rho]0", "-", 
      RowBox[{"avgx2\[Rho]0", "*", "avgp2\[Rho]0"}]}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Build", " ", "quadratic", " ", "block"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"M", "=", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{"Gxx", ",", "Gxp"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"Gxp", ",", "Gpp"}], "}"}]}], "}"}], "//", 
      "FullSimplify"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"M", "//", "MatrixForm"}], "\[IndentingNewLine]"}]}]], "Input",
