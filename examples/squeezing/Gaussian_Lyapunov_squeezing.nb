Cell[BoxData[
 RowBox[{
  RowBox[{"covSqueezed", "[", "\[Theta]_", "]"}], ":=", 
  RowBox[{"(", GridBox[{
     {
      RowBox[{"Vxx", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{
         RowBox[{"-", "2"}], "\[Theta]"}], "]"}]}], "0"},
     {"0", 
      RowBox[{"Vpp", "*", 
       RowBox[{"Exp", "[", 
        RowBox[{"2", "\[Theta]"}], "]"}]}]}
    }], ")"}]}]], "Input",
