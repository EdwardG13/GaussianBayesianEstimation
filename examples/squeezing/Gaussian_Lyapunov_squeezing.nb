    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"\[Mu]0", "+", 
        FractionBox[
         SuperscriptBox["\[Sigma]0", "2"], "2"]}]], " ", 
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox["\[Mu]p", "2"], "-", 
        RowBox[{"2", " ", 
         SuperscriptBox["\[ExponentialE]", 
          SuperscriptBox["\[Sigma]0", "2"]], " ", 
         SuperscriptBox["\[Mu]p", "2"]}], "+", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{"2", " ", 
           SuperscriptBox["\[Sigma]0", "2"]}]], " ", 
         RowBox[{"(", 
          RowBox[{"Vpp", "+", 
           SuperscriptBox["\[Mu]p", "2"]}], ")"}]}]}], ")"}], " ", "\[Mu]x", " ", 
      SuperscriptBox["\[Sigma]0", "2"]}], 
     RowBox[{
      RowBox[{
       RowBox[{"-", 
        SuperscriptBox["\[Mu]p", "2"]}], " ", 
       SuperscriptBox["\[Mu]x", "2"]}], "+", 
      RowBox[{"2", " ", 
       SuperscriptBox["\[ExponentialE]", 
        SuperscriptBox["\[Sigma]0", "2"]], " ", 
       SuperscriptBox["\[Mu]p", "2"], " ", 
       SuperscriptBox["\[Mu]x", "2"]}], "+", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"4", " ", 
         SuperscriptBox["\[Sigma]0", "2"]}]], " ", 
       RowBox[{"(", 
        RowBox[{"Vpp", "+", 
         SuperscriptBox["\[Mu]p", "2"]}], ")"}], " ", 
       RowBox[{"(", 
        RowBox[{"Vxx", "+", 
         SuperscriptBox["\[Mu]x", "2"]}], ")"}]}], "-", 
      RowBox[{
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"3", " ", 
         SuperscriptBox["\[Sigma]0", "2"]}]], " ", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"Vxx", " ", 
          SuperscriptBox["\[Mu]p", "2"]}], "+", 
         RowBox[{
          RowBox[{"(", 
           RowBox[{"Vpp", "+", 
            RowBox[{"2", " ", 
             SuperscriptBox["\[Mu]p", "2"]}]}], ")"}], " ", 
          SuperscriptBox["\[Mu]x", "2"]}]}], ")"}]}]}]]}], ",", 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{
       RowBox[{"-", "\[Mu]0"}], "+", 
       FractionBox[
        SuperscriptBox["\[Sigma]0", "2"], "2"]}]], " ", "\[Mu]p", " ", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["\[Mu]x", "2"], "-", 
       RowBox[{"2", " ", 
        SuperscriptBox["\[ExponentialE]", 
         SuperscriptBox["\[Sigma]0", "2"]], " ", 
        SuperscriptBox["\[Mu]x", "2"]}], "+", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", " ", 
          SuperscriptBox["\[Sigma]0", "2"]}]], " ", 
        RowBox[{"(", 
         RowBox[{"Vxx", "+", 
          SuperscriptBox["\[Mu]x", "2"]}], ")"}]}]}], ")"}], " ", 
     SuperscriptBox["\[Sigma]0", "2"]}], 
    RowBox[{
     RowBox[{
      RowBox[{"-", 
       SuperscriptBox["\[Mu]p", "2"]}], " ", 
      SuperscriptBox["\[Mu]x", "2"]}], "+", 
     RowBox[{"2", " ", 
      SuperscriptBox["\[ExponentialE]", 
       SuperscriptBox["\[Sigma]0", "2"]], " ", 
      SuperscriptBox["\[Mu]p", "2"], " ", 
      SuperscriptBox["\[Mu]x", "2"]}], "+", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"4", " ", 
        SuperscriptBox["\[Sigma]0", "2"]}]], " ", 
      RowBox[{"(", 
       RowBox[{"Vpp", "+", 
        SuperscriptBox["\[Mu]p", "2"]}], ")"}], " ", 
      RowBox[{"(", 
       RowBox[{"Vxx", "+", 
        SuperscriptBox["\[Mu]x", "2"]}], ")"}]}], "-", 
     RowBox[{
      SuperscriptBox["\[ExponentialE]", 
       RowBox[{"3", " ", 
        SuperscriptBox["\[Sigma]0", "2"]}]], " ", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"Vxx", " ", 
         SuperscriptBox["\[Mu]p", "2"]}], "+", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"Vpp", "+", 
           RowBox[{"2", " ", 
            SuperscriptBox["\[Mu]p", "2"]}]}], ")"}], " ", 
         SuperscriptBox["\[Mu]x", "2"]}]}], ")"}]}]}]]}], "}"}]], "Output",
 CellChangeTimes->{{3.980065021268078*^9, 3.9800650404263935`*^9}, {
   3.980065677447798*^9, 3.980065684017559*^9}, 3.980524123991741*^9, 
   3.9805241770862236`*^9, 3.9805242690345974`*^9, 3.980527729090313*^9, 
   3.980583455135912*^9, 3.9811772643286324`*^9, 3.981529815684572*^9, 
   3.9817895668892765`*^9, 3.981790730181904*^9},
 CellLabel->"Out[26]=",ExpressionUUID->"2da8ddd5-feea-d549-9cee-01498bf9b089"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"-", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[ExponentialE]", "\[Mu]0"], " ", "\[Mu]x", " ", 
      SuperscriptBox["\[Sigma]0", "2"]}], "Vxx"]}], ",", 
   FractionBox[
    RowBox[{
     SuperscriptBox["\[ExponentialE]", 
      RowBox[{"-", "\[Mu]0"}]], " ", "\[Mu]p", " ", 
     SuperscriptBox["\[Sigma]0", "2"]}], "Vpp"]}], "}"}]], "Output",
 CellChangeTimes->{{3.980065021268078*^9, 3.9800650404263935`*^9}, {
