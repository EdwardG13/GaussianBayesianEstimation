Cell[TextData[{
 "Use the linear basis ",
 Cell[BoxData[
  FormBox[
   RowBox[{"B", "=", 
    RowBox[{"{", 
     RowBox[{"1", ",", "\[CapitalDelta]x", ",", "\[CapitalDelta]p"}]}]}], 
   TraditionalForm]],ExpressionUUID->"77170fa4-3d42-be4d-a3e8-592736c28dce"],
 "} where ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[CapitalDelta]x", "=", 
    RowBox[{
     OverscriptBox["x", "^"], "-", 
     RowBox[{"Tr", "(", 
      RowBox[{
       SubscriptBox["\[Rho]", "0"], 
       OverscriptBox["x", "^"]}], ")"}]}]}], TraditionalForm]],ExpressionUUID->
  "57e0d1e5-16d8-f446-957a-1cf37e854052"],
 " and similarly for p."
}], "Text",
 CellFrame->{{0, 0}, {0, 0}},
 CellChangeTimes->{{3.9805238330961475`*^9, 3.980523890804899*^9}, {
  3.981789414886307*^9, 3.9817894357942715`*^9}},
