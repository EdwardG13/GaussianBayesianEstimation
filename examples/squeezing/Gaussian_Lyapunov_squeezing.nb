Cell[CellGroupData[{

Cell["Symmetric logarithmic derivative (SLD)", "Subsection",
 CellChangeTimes->{{3.6520949429746923`*^9, 
  3.652094951849272*^9}},ExpressionUUID->"029b1340-2682-2248-aba5-\
02df89d4e50e"],

Cell[TextData[{
 "We want to obtain the symmetric logarithmic derivative. For a Gaussian \
state, it is a quadratic form of position and momentum (",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "f99d9d0e-9838-b44d-b08e-4356bf181c83"],
 " and ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "0d11133b-8842-8a45-8cdb-953c80554979"],
 ") \n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[ScriptCapitalL]", "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["\[Sum]", "ij"], " ", 
      RowBox[{
       SubscriptBox["L", "ij"], " ", 
       FractionBox["1", "2"], 
       SubscriptBox[
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           SubscriptBox["R", "i"], "-", 
           SubscriptBox["d", "i"]}], ",", 
          RowBox[{
           SubscriptBox["R", "j"], "-", 
           SubscriptBox["d", "j"]}]}], "}"}], "+"]}]}], "+", 
     RowBox[{
      SubscriptBox["\[Sum]", "i"], 
      RowBox[{
       SubscriptBox["b", "i"], "(", 
       RowBox[{
        SubscriptBox["R", "i"], "-", 
        SubscriptBox["d", "i"]}], ")"}]}], "-", 
     RowBox[{
      FractionBox["1", "2"], "tr", 
      RowBox[{"{", 
       StyleBox[
        RowBox[{"L", " ", "\[CapitalGamma]"}],
        FontWeight->"Bold"], "}"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "943f45ff-f781-f34a-a6a4-060de4447e02"],
 ",\n\nhere, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["d", "i"], "=", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox["R", "i"], "\[RightAngleBracket]"}], "=", 
     RowBox[{"tr", 
      RowBox[{"{", 
       RowBox[{
        SubscriptBox["R", "i"], "\[Rho]"}], "}"}]}]}]}], TraditionalForm]],
  ExpressionUUID->"84733a7e-e200-a547-be49-38360508244d"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["R", "\[Rule]"], "=", 
    RowBox[{"(", 
     RowBox[{"x", ",", "p"}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "cf583360-f7dd-144b-a5a7-0a72ed629421"],
 ", ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["\[CapitalGamma]",
     FontWeight->"Bold"], "=", 
    RowBox[{"2", 
     StyleBox["\[Sigma]",
      FontWeight->"Bold"]}]}], TraditionalForm]],ExpressionUUID->
  "e5db91ef-6707-4547-8bdd-b67f8df80faa"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Sigma]", "ij"], "=", 
    RowBox[{
     FractionBox["1", "2"], 
     RowBox[{"\[LeftAngleBracket]", 
      SubscriptBox[
       RowBox[{"{", 
        RowBox[{
         SubscriptBox["R", "i"], ",", 
         SubscriptBox["R", "j"]}], "}"}], "+"], "\[RightAngleBracket]"}]}]}], 
   TraditionalForm]],ExpressionUUID->"3a7d3ecc-00dc-6547-9374-909bb75e99d1"],
 " are the elements of the (symmetrized) covariance matrix. See Monras (2013) \
https://arxiv.org/pdf/1303.3682."
}], "Text",
 CellChangeTimes->{{3.6522528959283752`*^9, 3.6522528997803583`*^9}, {
  3.652252984348523*^9, 3.652252986882021*^9}, {3.9817898712708893`*^9, 
  3.981789900635914*^9}},
 Background->RGBColor[
  0.94, 0.91, 0.88],ExpressionUUID->"618f600b-c654-3d49-a2fc-e4e583f698ee"],

Cell[TextData[{
 "Here, ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["\[CapitalOmega]",
     FontWeight->"Bold"], "=", 
    RowBox[{"(", GridBox[{
       {"0", 
        RowBox[{"-", "1"}]},
       {"1", "0"}
      }], ")"}]}], TraditionalForm]],ExpressionUUID->
  "cc7bcebb-5129-c94e-bab9-80a1f5949e6f"],
 " is the symplectic matrix. \n\nThe coefficients are given by\n\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["L",
     FontWeight->"Bold"], "=", 
    RowBox[{
     SuperscriptBox[
      SubscriptBox["\[ScriptCapitalD]", 
       StyleBox["\[CapitalGamma]",
        FontWeight->"Bold"]], 
      RowBox[{"-", "1"}]], "(", 
     RowBox[{"\[PartialD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]}], ")"}]}], TraditionalForm]],ExpressionUUID->
  "f9aceb0d-7dd8-5847-9a2e-0155a0ae2d52"],
 "\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["b", "\[Rule]"], "=", 
    RowBox[{"2", 
     SuperscriptBox[
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"], 
      RowBox[{"-", "1"}]], 
     RowBox[{"\[PartialD]", 
      OverscriptBox["d", "\[Rule]"]}]}]}], TraditionalForm]],ExpressionUUID->
  "cbdbf4d2-77db-fa43-bbed-c29ecc1dc91b"],
 ",\n\nwhere the application ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     RowBox[{
      SubscriptBox["\[ScriptCapitalD]", 
       StyleBox["\[CapitalGamma]",
        FontWeight->"Bold"]], "(", 
      StyleBox["Y",
       FontWeight->"Bold"], ")"}], "=", 
     RowBox[{
      RowBox[{
       StyleBox["\[CapitalGamma]",
        FontWeight->"Bold"], " ", 
       StyleBox["Y",
        FontWeight->"Bold"], " ", 
       SuperscriptBox[
        StyleBox["\[CapitalGamma]",
         FontWeight->"Bold"], "T"]}], "-", 
      RowBox[{
       StyleBox["\[CapitalOmega]",
        FontWeight->"Bold"], " ", 
       StyleBox["Y",
        FontWeight->"Bold"], " ", 
       SuperscriptBox[
        StyleBox["\[CapitalOmega]",
         FontWeight->"Bold"], "T"]}]}]}], ","}], TraditionalForm]],
  ExpressionUUID->"d7edfd30-935b-844c-91b0-6ea5655e58ed"],
 " and \[PartialD] is a shorthand for \[PartialD]/\[PartialD]\[Theta]. Hence, \
",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     SubscriptBox["\[ScriptCapitalD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]], 
     RowBox[{"-", "1"}]], "(", 
    RowBox[{"\[PartialD]", 
     StyleBox["\[CapitalGamma]",
      FontWeight->"Bold"]}], ")"}], TraditionalForm]],ExpressionUUID->
  "2a66fadf-f4c0-8045-9510-0f1236163cea"],
 " is the solution ",
 StyleBox["Y",
  FontWeight->"Bold"],
 " to the matrix equation\n\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"\[PartialD]", 
     StyleBox["\[CapitalGamma]",
      FontWeight->"Bold"]}], "=", 
    RowBox[{
     RowBox[{
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"], " ", 
      StyleBox["Y",
       FontWeight->"Bold"], " ", 
      SuperscriptBox[
       StyleBox["\[CapitalGamma]",
        FontWeight->"Bold"], "T"]}], "-", 
     RowBox[{
      StyleBox["\[CapitalOmega]",
       FontWeight->"Bold"], " ", 
      StyleBox["Y",
       FontWeight->"Bold"], " ", 
      SuperscriptBox[
       StyleBox["\[CapitalOmega]",
        FontWeight->"Bold"], "T"]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      StyleBox["\[CapitalOmega]",
       FontWeight->"Bold"], 
      RowBox[{"-", "1"}]], 
     RowBox[{"\[PartialD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]}], " ", 
     SuperscriptBox[
      RowBox[{"(", 
       SuperscriptBox[
        StyleBox["\[CapitalOmega]",
         FontWeight->"Bold"], "T"], ")"}], 
      RowBox[{"-", "1"}]]}], "=", 
    RowBox[{
     RowBox[{
      SuperscriptBox[
       StyleBox["\[CapitalOmega]",
        FontWeight->"Bold"], 
       RowBox[{"-", "1"}]], 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"], " ", 
      StyleBox["Y",
       FontWeight->"Bold"], " ", 
      SuperscriptBox[
       RowBox[{
        SuperscriptBox[
         StyleBox["\[CapitalGamma]",
          FontWeight->"Bold"], "T"], "(", 
        SuperscriptBox[
         StyleBox["\[CapitalOmega]",
          FontWeight->"Bold"], "T"], ")"}], 
       RowBox[{"-", "1"}]]}], "-", 
     StyleBox["Y",
      FontWeight->"Bold"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SuperscriptBox[
      StyleBox["\[CapitalOmega]",
       FontWeight->"Bold"], "T"], 
     RowBox[{"\[PartialD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]}], 
     StyleBox[" ",
      FontWeight->"Bold"], 
     StyleBox["\[CapitalOmega]",
      FontWeight->"Bold"]}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        SuperscriptBox[
         StyleBox["\[CapitalOmega]",
          FontWeight->"Bold"], "T"], 
        StyleBox["\[CapitalGamma]",
         FontWeight->"Bold"]}], ")"}], 
      SuperscriptBox[
       RowBox[{
        StyleBox["Y",
         FontWeight->"Bold"], "(", 
        RowBox[{
         SuperscriptBox[
          StyleBox["\[CapitalOmega]",
           FontWeight->"Bold"], "T"], 
         StyleBox["\[CapitalGamma]",
          FontWeight->"Bold"]}], ")"}], "T"]}], "-", 
     StyleBox["Y",
      FontWeight->"Bold"]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     StyleBox["Y",
      FontWeight->"Bold"], 
     StyleBox["-",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox["F",
       FontWeight->"Bold"], 
      StyleBox[" ",
       FontWeight->"Bold"], 
      StyleBox["Y",
       FontWeight->"Bold"], 
      StyleBox[" ",
       FontWeight->"Bold"], 
      SuperscriptBox[
       StyleBox["F",
        FontWeight->"Bold"], "T"]}]}], "=", 
    RowBox[{
     RowBox[{
      StyleBox["-",
       FontWeight->"Bold"], 
      SuperscriptBox[
       StyleBox["\[CapitalOmega]",
        FontWeight->"Bold"], "T"]}], 
     RowBox[{"\[PartialD]", 
      StyleBox["\[CapitalGamma]",
       FontWeight->"Bold"]}], 
     StyleBox[" ",
      FontWeight->"Bold"], 
     RowBox[{
      StyleBox["\[CapitalOmega]",
       FontWeight->"Bold"], "."}]}]}], TraditionalForm]}],ExpressionUUID->
  "d7c7d367-dd8d-df45-a011-dc8e7804118d"],
 "\n\nIn our case, we have"
}], "Text",
 CellChangeTimes->{{3.652253037031055*^9, 3.6522530522470703`*^9}, {
   3.6522532310445347`*^9, 3.6522532336786747`*^9}, 3.652254652824998*^9, {
   3.9816108863991127`*^9, 3.981610887282446*^9}, {3.9817899058560505`*^9, 
