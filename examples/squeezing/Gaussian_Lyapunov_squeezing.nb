          SuperscriptBox["\[ExponentialE]", 
           RowBox[{"2", " ", "\[Theta]"}]], " ", "Vpp"}], 
         RowBox[{
          RowBox[{"4", " ", "Vpp", " ", "Vxx"}], "+", "1"}]]}], "0"},
      {"0", 
       FractionBox[
        RowBox[{"4", " ", 
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], " ", "\[Theta]"}]], " ", "Vxx"}], 
