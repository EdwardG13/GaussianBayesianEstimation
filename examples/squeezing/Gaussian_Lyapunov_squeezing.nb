      RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Mixed", " ", "moment"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgxp\[Rho]0", "=", 
