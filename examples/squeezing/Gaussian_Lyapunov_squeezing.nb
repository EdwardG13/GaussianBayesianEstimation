Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"p", "[", "\[Theta]_", "]"}], ":=", 
    RowBox[{"PDF", "[", 
     RowBox[{
      RowBox[{"NormalDistribution", "[", 
       RowBox[{"\[Mu]0", ",", "\[Sigma]0"}], "]"}], ",", "\[Theta]"}], 
     "]"}]}], ";"}], "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"First", " ", "moments"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"avgx\[Rho]0", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{"\[Mu]x", " ", 
     RowBox[{"Exp", "[", 
      RowBox[{"-", " ", "\[Theta]"}], "]"}], " ", 
     RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
     RowBox[{"\[Theta]", ",", 
      RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
    RowBox[{"Assumptions", "->", 
     RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"avgp\[Rho]0", "=", 
   RowBox[{"Integrate", "[", 
    RowBox[{
     RowBox[{"\[Mu]p", " ", 
      RowBox[{"Exp", "[", " ", "\[Theta]", "]"}], " ", 
      RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"\[Theta]", ",", 
       RowBox[{"-", "Infinity"}], ",", "Infinity"}], "}"}], ",", 
     RowBox[{"Assumptions", "->", 
      RowBox[{"\[Sigma]0", ">", "0"}]}]}], "]"}]}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{"Second", " ", "moments"}], "*)"}]}], "\[IndentingNewLine]", 
 RowBox[{"avgx2\[Rho]0", "=", 
  RowBox[{"Integrate", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"Vxx", "+", 
       SuperscriptBox["\[Mu]x", "2"]}], ")"}], " ", 
     RowBox[{"Exp", "[", 
      RowBox[{
       RowBox[{"-", "2"}], " ", "\[Theta]"}], "]"}], " ", 
     RowBox[{"p", "[", "\[Theta]", "]"}]}], ",", 
    RowBox[{"{", 
