       Scaled[0.05]}}, Ticks -> {Automatic, Automatic}], 
   FormBox[
    FormBox[
     TemplateBox[{
       InterpretationBox[
       "\"\[Mu]=\\!\\(\\*FormBox[\\\"0.1`\\\", TraditionalForm]\\)\"", 
        StringForm["\[Mu]=``", 0.1], Editable -> False], 
       InterpretationBox[
       "\"\[Mu]=\\!\\(\\*FormBox[\\\"0.5`\\\", TraditionalForm]\\)\"", 
        StringForm["\[Mu]=``", 0.5], Editable -> False], 
       InterpretationBox[
       "\"\[Mu]=\\!\\(\\*FormBox[\\\"1\\\", TraditionalForm]\\)\"", 
        StringForm["\[Mu]=``", 1], Editable -> False]}, "LineLegend", 
      DisplayFunction -> (FormBox[
        StyleBox[
